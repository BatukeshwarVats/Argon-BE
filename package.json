{
  "name": "argon-be",
  "version": "0.1.0",
  "description": "Image upload + validation pipeline backend (Aragon.ai SDE-2 assignment)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:processing": "tsx watch src/processing.ts",
    "dev:convert": "PROCESSING_SERVICE=convert tsx watch src/processing.ts",
    "dev:compress": "PROCESSING_SERVICE=compress tsx watch src/processing.ts",
    "dev:variants": "PROCESSING_SERVICE=variants tsx watch src/processing.ts",
    "dev": "concurrently -n api,validate,pipeline -c blue,magenta,green \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:processing\"",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:processing": "node dist/processing.js",
    "loadtest": "tsx scripts/load-test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "setup:minio": "tsx scripts/setup-minio.ts",
    "setup:models": "tsx scripts/download-face-models.ts",
    "bootstrap": "npm run infra:up && sleep 5 && npm run prisma:migrate && npm run setup:minio && npm run setup:models",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.18.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.13",
    "bullmq": "^5.12.0",
    "canvas": "^2.11.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "file-type": "^16.5.4",
    "heic-convert": "^2.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.1",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "sharp": "^0.33.4",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/heic-convert": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.18.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
