# ──────────────────────────────────────────────────────────────
# Argon-BE environment configuration
# Copy to `.env` and adjust as needed for local development.
# ──────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# Database (docker compose maps host 5433 → container 5432 to avoid clashing
# with a locally-installed postgres on 5432)
DATABASE_URL=postgresql://argon:argon@localhost:5433/argon?schema=public

# Redis (BullMQ) — host 6380 → container 6379, same reasoning as postgres
REDIS_HOST=localhost
REDIS_PORT=6380

# S3 / MinIO
# For MinIO (local dev), use the credentials defined in docker-compose.yml.
# For AWS S3, set AWS_S3_ENDPOINT to empty string and provide real keys.
AWS_REGION=us-east-1
AWS_S3_BUCKET=argon-images
AWS_S3_ENDPOINT=http://localhost:9100
AWS_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=argonadmin
AWS_SECRET_ACCESS_KEY=argonadmin

# Upload constraints
UPLOAD_MAX_BYTES=15728640        # 15 MB
SIGNED_URL_TTL_SECONDS=600       # 10 min

# Validation thresholds (tunable without code changes)
MIN_WIDTH=200
MIN_HEIGHT=200
MIN_FILE_BYTES=8192              # 8 KB — rejects pathologically tiny files
BLUR_VARIANCE_THRESHOLD=80       # Laplacian variance below this = blurry
FACE_MIN_AREA_RATIO=0.05         # face bbox must cover >= 5% of image area
FACE_MAX_COUNT=1                 # > 1 face → reject
SIMILARITY_HAMMING_THRESHOLD=5   # pHash Hamming distance <= 5 → duplicate

# Face detection model path (downloaded by `npm run setup:models`)
FACE_MODEL_PATH=./models
